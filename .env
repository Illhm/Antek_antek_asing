# ============================================
# IPTV Panel SQLite/Railway Environment
# ============================================

PANEL_NAME=Tipistream Panel
PANEL_URL=
TIMEZONE=Asia/Jakarta

# SQLite database path
# Railway production should use /data/database.sqlite
# Local fallback can use db/database.sqlite
SQLITE_DB_PATH=/data/database.sqlite

# Default bootstrap admin
# Only used when admin table is empty / admin does not exist
ADMIN_USERNAME=admin
ADMIN_PASSWORD=1
ADMIN_ROLE=superadmin

# Security
SECRET_KEY=HepvoTxhMUiiauDe+x6w2pGO/S6LAnYgXm9LLuPeeWkrHhMlbz8XFu7UOesPQ9x+VQWJaF4pKYf7b1u0lg/bag==

# Token/session expiration
TOKEN_EXPIRE_HOURS=6
SESSION_EXPIRE=3600
PROXY_EXPIRE_SECONDS=7200

# Rate limit
RATE_LIMIT_REQUESTS=300
RATE_LIMIT_WINDOW=60

# Stream security
MAX_CONCURRENT_STREAMS_PER_USER=1
STREAM_SESSION_POLICY=block_new
STREAM_IDLE_TIMEOUT=90
STREAM_SESSION_MAX_AGE=21600

# Signed proxy URLs
PLAYLIST_SIGNED_TTL=120
SEGMENT_SIGNED_TTL=60

# Client binding
IP_BIND_MODE=soft
STRICT_CLIENT_BINDING=false

# Optional default/free playlist source
FREE_PLAYLIST_URL=https://iptv.tipime.my.id/data/playlists/free.m3u
